generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * |--------------------------------------------------------------------------
 * | Global user roles
 * |--------------------------------------------------------------------------
 * |
 * | PLATFORM_ADMIN:
 * | Pronari ose administratori i platformës AutoFlow.
 * |
 * | CUSTOMER:
 * | Klienti final që përdor portalin e klientit.
 * |
 * | OWNER, MANAGER, MECHANIC etj. nuk vendosen këtu.
 * | Ato vendosen te BusinessUser, sepse një përdorues mund të ketë role
 * | të ndryshme në biznese të ndryshme.
 * |
 */

enum UserRole {
  PLATFORM_ADMIN
  CUSTOMER
}

/**
 * |--------------------------------------------------------------------------
 * | Business roles
 * |--------------------------------------------------------------------------
 * |
 * | Këto janë rolet e përdoruesve brenda një servisi specifik.
 * |
 */

enum BusinessRole {
  OWNER
  MANAGER
  MECHANIC
  RECEPTIONIST
  WAREHOUSE
  ACCOUNTANT
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  ENGINE_OIL
  OIL_FILTER
  AIR_FILTER
  CABIN_FILTER
  FUEL_FILTER
  BRAKE_FLUID
  COOLANT
  TIMING_BELT
  GEARBOX_OIL
  BRAKES
  BATTERY
  TIRES
  SPARK_PLUGS
  OTHER
}

enum MaintenanceStatus {
  OK
  SOON
  OVERDUE
}

enum InvoiceStatus {
  DRAFT
  PAID
  UNPAID
  OVERDUE
}

enum PurchaseStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationEntity {
  MARKETPLACE
  SERVICE
  VEHICLE
  APPOINTMENT
  CUSTOMER
  BUSINESS
  PAYMENT
  SUBSCRIPTION
  DOCUMENT
  SYSTEM
}

/**
 * |--------------------------------------------------------------------------
 * | Marketplace enums
 * |--------------------------------------------------------------------------
 */

enum MarketplaceSellerType {
  BUSINESS
  USER
}

enum MarketplaceListingType {
  VEHICLE
  MOTORCYCLE
  PART
  ACCESSORY
  SERVICE
  OTHER
}

enum MarketplaceListingStatus {
  DRAFT
  PUBLISHED
  SOLD
  ARCHIVED
  REJECTED
}

enum VehicleClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  PAYMENT
  CUSTOM
}

/**
 * |--------------------------------------------------------------------------
 * | User
 * |--------------------------------------------------------------------------
 */

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  passwordHash  String?
  globalRole    UserRole?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  businesses BusinessUser[]

  customerProfile CustomerProfile?

  marketplaceListings  MarketplaceListing[]  @relation("MarketplaceUserListings")
  marketplaceFavorites MarketplaceFavorite[]
  marketplaceInquiries MarketplaceInquiry[]  @relation("MarketplaceInquirySender")
  notifications        Notification[]
  auditLogs            AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([globalRole])
  @@index([isActive])
}

model CustomerProfile {
  id     String @id @default(cuid())
  userId String @unique

  firstName String?
  lastName  String?

  phone   String?
  city    String?
  address String?

  birthDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicles CustomerVehicle[]

  @@index([userId])
}

/**
 * |--------------------------------------------------------------------------
 * | Business
 * |--------------------------------------------------------------------------
 */

model Business {
  id           String   @id @default(cuid())
  name         String
  nipt         String?  @unique
  city         String?
  address      String?
  phone        String?
  email        String?
  website      String?
  logo         String?
  workingHours String?
  currency     String   @default("ALL")
  vat          Float    @default(20)
  timezone     String   @default("Europe/Tirane")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users               BusinessUser[]
  customers           Customer[]
  vehicles            Vehicle[]
  services            ServiceRecord[]
  appointments        Appointment[]
  parts               Part[]
  invoices            Invoice[]
  purchaseOrders      PurchaseOrder[]
  marketplaceListings MarketplaceListing[] @relation("MarketplaceBusinessListings")
  notifications       Notification[]
  auditLogs           AuditLog[]

  @@index([name])
  @@index([city])
  @@index([email])
  @@index([phone])
  @@index([isActive])
}

/**
 * |--------------------------------------------------------------------------
 * | BusinessUser
 * |--------------------------------------------------------------------------
 * |
 * | Lidh një përdorues me një biznes.
 * |
 * | Shembull:
 * | owner@autoflow.al
 * | OWNER
 * | Auto Service Fier
 * |
 */

model BusinessUser {
  id         String       @id @default(cuid())
  userId     String
  businessId String
  role       BusinessRole @default(OWNER)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@index([businessId, role])
  @@index([businessId, isActive])
}

/**
 * |--------------------------------------------------------------------------
 * | Customer
 * |--------------------------------------------------------------------------
 */

model Customer {
  id         String   @id @default(cuid())
  businessId String
  name       String
  phone      String?
  email      String?
  city       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]
  invoices     Invoice[]
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, phone])
  @@index([businessId, email])
}

/**
 * |--------------------------------------------------------------------------
 * | Vehicle
 * |--------------------------------------------------------------------------
 */

model Vehicle {
  id         String   @id @default(cuid())
  businessId String
  customerId String?
  plate      String
  brand      String
  model      String?
  year       Int?
  vin        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  services         ServiceRecord[]
  appointments     Appointment[]
  invoices         Invoice[]
  portalClaims     VehicleClaim[]
  customerLinks    CustomerVehicleLink[]
  maintenanceItems MaintenanceItem[]

  @@unique([businessId, plate])
  @@index([businessId])
  @@index([customerId])
  @@index([businessId, brand])
  @@index([businessId, vin])
}

model CustomerVehicle {
  id String @id @default(cuid())

  profileId String

  plate String

  brand String
  model String?

  year Int?

  fuel String?

  engine String?

  transmission String?

  vin String?

  mileage Int?

  color String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile CustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  claims VehicleClaim[]
  links  CustomerVehicleLink[]

  @@unique([profileId, plate])
  @@index([profileId])
  @@index([plate])
  @@index([brand])
  @@index([vin])
}

model VehicleClaim {
  id String @id @default(cuid())

  customerVehicleId String
  vehicleId         String

  status VehicleClaimStatus @default(PENDING)

  customerMessage String?
  rejectionReason String?

  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerVehicle CustomerVehicle @relation(fields: [customerVehicleId], references: [id], onDelete: Cascade)
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([customerVehicleId, vehicleId])
  @@index([customerVehicleId])
  @@index([vehicleId])
  @@index([status])
  @@index([vehicleId, status])
}

model CustomerVehicleLink {
  id String @id @default(cuid())

  customerVehicleId String
  vehicleId         String

  isActive Boolean @default(true)

  linkedAt   DateTime  @default(now())
  unlinkedAt DateTime?

  customerVehicle CustomerVehicle @relation(fields: [customerVehicleId], references: [id], onDelete: Cascade)
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([customerVehicleId, vehicleId])
  @@index([customerVehicleId])
  @@index([vehicleId])
  @@index([isActive])
  @@index([customerVehicleId, isActive])
  @@index([vehicleId, isActive])
}

model MaintenanceItem {
  id String @id @default(cuid())

  vehicleId       String
  serviceRecordId String?

  type   MaintenanceType
  title  String
  status MaintenanceStatus @default(OK)

  lastMileage Int?
  nextMileage Int?
  intervalKm  Int?

  lastDate DateTime?
  nextDate DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceRecord ServiceRecord? @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([serviceRecordId])
  @@index([type])
  @@index([status])
  @@index([vehicleId, status])
  @@index([vehicleId, type])
}

/**
 * |--------------------------------------------------------------------------
 * | ServiceRecord
 * |--------------------------------------------------------------------------
 */

model ServiceRecord {
  id          String        @id @default(cuid())
  businessId  String
  vehicleId   String
  customerId  String?
  title       String
  description String?
  status      ServiceStatus @default(PENDING)
  total       Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  invoice          Invoice?
  partsUsed        ServicePartUsage[]
  maintenanceItems MaintenanceItem[]

  @@index([businessId])
  @@index([vehicleId])
  @@index([customerId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

/**
 * |--------------------------------------------------------------------------
 * | Appointment
 * |--------------------------------------------------------------------------
 */

model Appointment {
  id          String        @id @default(cuid())
  businessId  String
  vehicleId   String?
  customerId  String?
  title       String
  description String?
  date        DateTime
  status      ServiceStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([vehicleId])
  @@index([customerId])
  @@index([businessId, date])
  @@index([businessId, status])
}

/**
 * |--------------------------------------------------------------------------
 * | Part
 * |--------------------------------------------------------------------------
 */

model Part {
  id         String   @id @default(cuid())
  businessId String
  code       String?
  name       String
  category   String?
  supplier   String?
  stock      Int      @default(0)
  minStock   Int      @default(0)
  buyPrice   Float    @default(0)
  sellPrice  Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business      Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceUsages ServicePartUsage[]

  @@unique([businessId, code])
  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, category])
  @@index([businessId, stock])
}

/**
 * |--------------------------------------------------------------------------
 * | PurchaseOrder
 * |--------------------------------------------------------------------------
 */

model PurchaseOrder {
  id         String         @id @default(cuid())
  businessId String
  supplier   String
  status     PurchaseStatus @default(PENDING)
  total      Float          @default(0)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, supplier])
}

/**
 * |--------------------------------------------------------------------------
 * | PurchaseOrderItem
 * |--------------------------------------------------------------------------
 */

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  name            String
  quantity        Int    @default(1)
  unitPrice       Float  @default(0)
  total           Float  @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

/**
 * |--------------------------------------------------------------------------
 * | ServicePartUsage
 * |--------------------------------------------------------------------------
 */

model ServicePartUsage {
  id        String   @id @default(cuid())
  serviceId String
  partId    String
  quantity  Int      @default(1)
  unitPrice Float    @default(0)
  total     Float    @default(0)
  createdAt DateTime @default(now())

  service ServiceRecord @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  part    Part          @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([serviceId, partId])
  @@index([serviceId])
  @@index([partId])
}

/**
 * |--------------------------------------------------------------------------
 * | Invoice
 * |--------------------------------------------------------------------------
 */

model Invoice {
  id         String        @id @default(cuid())
  businessId String
  customerId String?
  vehicleId  String?
  serviceId  String?       @unique
  number     String
  status     InvoiceStatus @default(DRAFT)
  total      Float         @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vehicle  Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  service  ServiceRecord? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@unique([businessId, number])
  @@index([businessId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model BusinessApplication {
  id                 String            @id @default(cuid())
  businessName       String
  ownerName          String
  email              String
  phone              String
  city               String
  address            String?
  notes              String?
  status             ApplicationStatus @default(PENDING)
  rejectionReason    String?
  reviewedAt         DateTime?
  reviewedById       String?
  approvedBusinessId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status])
  @@index([email])
  @@index([city])
  @@index([createdAt])
}

/**
 * |--------------------------------------------------------------------------
 * | MarketplaceListing
 * |--------------------------------------------------------------------------
 */

model MarketplaceListing {
  id String @id @default(cuid())

  sellerType MarketplaceSellerType

  businessId   String?
  sellerUserId String?

  type   MarketplaceListingType
  status MarketplaceListingStatus @default(DRAFT)

  title       String
  slug        String  @unique
  description String?

  price        Float
  isNegotiable Boolean @default(false)

  category  String?
  condition String?

  city    String?
  address String?

  phone String?
  email String?

  brand          String?
  model          String?
  productionYear Int?
  mileage        Int?
  fuelType       String?
  transmission   String?
  engine         String?
  color          String?
  vin            String?

  stock Int?

  isFeatured  Boolean   @default(false)
  publishedAt DateTime?
  soldAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business? @relation("MarketplaceBusinessListings", fields: [businessId], references: [id], onDelete: Cascade)
  sellerUser User?     @relation("MarketplaceUserListings", fields: [sellerUserId], references: [id], onDelete: Cascade)

  images    MarketplaceListingImage[]
  favorites MarketplaceFavorite[]
  inquiries MarketplaceInquiry[]

  @@index([businessId])
  @@index([sellerUserId])
  @@index([sellerType])
  @@index([type])
  @@index([status])
  @@index([city])
  @@index([brand])
  @@index([price])
  @@index([publishedAt])
  @@index([createdAt])
  @@index([status, publishedAt])
  @@index([businessId, status])
  @@index([sellerUserId, status])
}

model MarketplaceListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, position])
}

model MarketplaceFavorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model MarketplaceInquiry {
  id String @id @default(cuid())

  listingId    String
  senderUserId String?

  name    String
  email   String?
  phone   String?
  message String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing    MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  senderUser User?              @relation("MarketplaceInquirySender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([senderUserId])
  @@index([isRead])
  @@index([createdAt])
  @@index([listingId, isRead])
}

model Notification {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title   String
  message String

  type NotificationType

  entityType NotificationEntity?
  entityId   String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([businessId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id String @id @default(cuid())

  businessId String
  userId     String?

  action     AuditAction
  entityType String
  entityId   String?

  title       String
  description String?

  oldValues Json?
  newValues Json?
  metadata  Json?

  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([businessId, createdAt])
  @@index([businessId, entityType, entityId])
  @@index([userId, createdAt])
}
