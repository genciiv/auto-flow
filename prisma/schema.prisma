generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLATFORM_ADMIN
  OWNER
  MANAGER
  MECHANIC
  RECEPTIONIST
  WAREHOUSE
  ACCOUNTANT
  CUSTOMER
  SUPPLIER
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  PAID
  UNPAID
  OVERDUE
}

enum PurchaseStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      UserRole @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses BusinessUser[]
}

model Business {
  id        String   @id @default(cuid())
  name      String
  city      String?
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          BusinessUser[]
  customers      Customer[]
  vehicles       Vehicle[]
  services       ServiceRecord[]
  appointments   Appointment[]
  parts          Part[]
  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]
}

model BusinessUser {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       UserRole @default(OWNER)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Customer {
  id         String   @id @default(cuid())
  businessId String
  name       String
  phone      String?
  email      String?
  city       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]
  invoices     Invoice[]
  appointments Appointment[]
}

model Vehicle {
  id         String   @id @default(cuid())
  businessId String
  customerId String?
  plate      String
  brand      String
  model      String?
  year       Int?
  vin        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  services     ServiceRecord[]
  appointments Appointment[]
  invoices     Invoice[]
}

model ServiceRecord {
  id          String        @id @default(cuid())
  businessId  String
  vehicleId   String
  customerId  String?
  title       String
  description String?
  status      ServiceStatus @default(PENDING)
  total       Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  invoice   Invoice?
  partsUsed ServicePartUsage[]
}

model Appointment {
  id          String        @id @default(cuid())
  businessId  String
  vehicleId   String?
  customerId  String?
  title       String
  description String?
  date        DateTime
  status      ServiceStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model Part {
  id         String   @id @default(cuid())
  businessId String
  code       String?
  name       String
  category   String?
  supplier   String?
  stock      Int      @default(0)
  minStock   Int      @default(0)
  buyPrice   Float    @default(0)
  sellPrice  Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business      Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceUsages ServicePartUsage[]
}

model PurchaseOrder {
  id         String         @id @default(cuid())
  businessId String
  supplier   String
  status     PurchaseStatus @default(PENDING)
  total      Float          @default(0)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  name            String
  quantity        Int    @default(1)
  unitPrice       Float  @default(0)
  total           Float  @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model ServicePartUsage {
  id        String   @id @default(cuid())
  serviceId String
  partId    String
  quantity  Int      @default(1)
  unitPrice Float    @default(0)
  total     Float    @default(0)
  createdAt DateTime @default(now())

  service ServiceRecord @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  part    Part          @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([serviceId, partId])
}

model Invoice {
  id         String        @id @default(cuid())
  businessId String
  customerId String?
  vehicleId  String?
  serviceId  String?       @unique
  number     String
  status     InvoiceStatus @default(DRAFT)
  total      Float         @default(0)
  createdAt  DateTime      @default(now())

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vehicle  Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  service  ServiceRecord? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}
